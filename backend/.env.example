# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Optional: override API base (Azure resource URL or local server, e.g. http://localhost:11434/v1)
LLM_API_BASE=
# Azure only:
LLM_API_VERSION=2024-02-15-preview

# GitHub
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Database & queue
# SQLite (local dev, no Docker):
DATABASE_URL=sqlite:///./reviewiq.db
# PostgreSQL (with docker compose):
# DATABASE_URL=postgresql://reviewiq:reviewiq@localhost:5432/reviewiq
REDIS_URL=redis://localhost:6379/0

# App
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RISK_THRESHOLD=70
WORKER_POLL_INTERVAL=1.0
